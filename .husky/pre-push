#!/bin/sh

echo "==> pre-push validation"

# backend tests run in the project venv to avoid relying on a globally
# installed pytest
if [ -x backend/venv/bin/python ]; then
  cd backend
  ./venv/bin/python -m pytest tests/ -v || exit 1
  cd ..
else
  echo "skipping backend tests — backend/venv not present"
fi

cd frontend
pnpm run build || exit 1
cd ..

if [ -d "rust-core" ] && command -v cargo >/dev/null 2>&1; then
  cd rust-core
  # --lib only — cdylib needs Python linkage that maturin sets up,
  # which we don't want to require for git-push hygiene checks
  cargo test --lib || exit 1
  cd ..
fi
